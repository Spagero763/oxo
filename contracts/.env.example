# Copy to contracts/.env and fill in. NEVER commit the real .env.
# Deployer private key (must hold CELO for gas). Used only for CLI deploys.
PRIVATE_KEY=
# Celo RPC. Mainnet: https://forno.celo.org
CELO_RPC=https://forno.celo.org
# Address your backend uses to settle game results (relayer).
RELAYER_ADDRESS=
