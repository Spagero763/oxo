# Copy to .env.local (and set the same in Vercel). NEVER commit real secrets.

# --- public (safe in the browser) ---
# Privy app id (login + embedded wallet)
NEXT_PUBLIC_PRIVY_APP_ID=cmqpvuppd001g0dl4txk3mmu5
# Deployed OXOArcade escrow on Celo mainnet
NEXT_PUBLIC_OXO_CONTRACT=0xb85EcAF971cd07799B674a81FDC1D0b364B52B96
# Set to 1 to turn ON real on-chain staking (off = demo play balance)
NEXT_PUBLIC_ONCHAIN_STAKING=0

# --- server only (NEVER expose) ---
# Private key of the contract's relayer (it calls settle()). Use a dedicated
# wallet funded with a little CELO for gas, set as relayer via setRelayer().
RELAYER_PRIVATE_KEY=
# Celo RPC for the settle backend
CELO_RPC=https://forno.celo.org
